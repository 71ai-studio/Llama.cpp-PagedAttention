{
  "_comment": "Cluster config cho distributed llama.cpp inference (RPC backend)",
  "_doc": "Mỗi node chạy: ./deploy.sh --config run/nodes.json --self <host>",

  "cluster_name": "llama-cluster",

  "model":        "Qwen3.5-27B-Q4_K_M.gguf",
  "context":      8192,
